{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "mcd-solucoes-eletricas.vercel.app" }
      ],
      "destination": "https://www.mcdsolucoeseletricas.com.br/$1",
      "permanent": true
    },
    {
      "source": "/blog/template-post.html",
      "destination": "/blog/",
      "permanent": false
    }
  ]
}
